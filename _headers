# Visual assets — versioned manually; rename or purge Cloudflare cache on change
/*.svg
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=31536000, immutable

/*.ico
  Cache-Control: public, max-age=31536000, immutable

# Unversioned JS — 30 days passes PSI; purge via Cloudflare dashboard for hot fixes
/consent.js
  Cache-Control: public, max-age=2592000
